{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["vite/client"],
    "paths": {
      "@voxply/i18n": ["../../web/i18n/index.ts"]
    }
  },
  "include": ["src", "../../web/i18n"],
  "exclude": ["../../web/i18n/check-coverage.ts"]
}
