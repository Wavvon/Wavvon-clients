{
  "productName": "Wavvon",
  "version": "0.3.2",
  "identifier": "com.wavvon.android",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "deep-link": {
      "mobile": [
        {
          "host": "wavvon.io",
          "pathPrefix": [
            "/invite"
          ]
        }
      ]
    }
  }
}
