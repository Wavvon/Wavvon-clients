{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["vite/client"],
    "paths": {
      "react": ["./node_modules/@types/react/index.d.ts"],
      "react/jsx-runtime": ["./node_modules/@types/react/jsx-runtime.d.ts"],
      "react/jsx-dev-runtime": ["./node_modules/@types/react/jsx-dev-runtime.d.ts"],
      "i18next": ["./node_modules/i18next"],
      "react-i18next": ["./node_modules/react-i18next"],
      "i18next-icu": ["./node_modules/i18next-icu"],
      "@components/*": ["./src/components/*"],
      "@shared/types": ["./src/types"],
      "@shared/utils/*": ["./src/utils/*"],
      "@shared/hooks/*": ["./src/hooks/*"],
      "@shared/constants": ["./src/constants"],
      "@platform": ["./src/platform/index"],
      "@wavvon/i18n": ["../../../packages/i18n/index.ts"],
      "@wavvon/core": ["../../../packages/core/src/index.ts"],
      "@wavvon/ui": ["../../../packages/ui/src/index.ts"],
      "@wavvon/ui/styles.css": ["../../../packages/ui/src/styles.css"],
      "@noble/curves/*": ["./node_modules/@wavvon/core/node_modules/@noble/curves/*"],
      "@noble/hashes/*": ["./node_modules/@wavvon/core/node_modules/@noble/hashes/*"],
      "@noble/ciphers/*": ["./node_modules/@wavvon/core/node_modules/@noble/ciphers/*"]
    }
  },
  "include": ["src", "../../../packages/ui/src"],
  "exclude": ["src/identity/wire.test.ts"]
}
