{
  "name": "wavvon-web",
  "version": "0.3.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:live": "playwright test --project=live --workers=1",
    "test:e2e:ui": "playwright test --ui",
    "check-i18n": "tsx ../../packages/i18n/check-coverage.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@mediapipe/selfie_segmentation": "^0.1.1675465747",
    "@noble/ciphers": "^1.0.0",
    "@noble/curves": "^1.7.0",
    "@noble/hashes": "^1.6.0",
    "@scure/bip39": "^1.4.0",
    "@types/dompurify": "^3.0.5",
    "@wavvon/core": "workspace:*",
    "@wavvon/i18n": "workspace:*",
    "@wavvon/ui": "workspace:*",
    "dompurify": "^3.4.8",
    "i18next": "^24.2.3",
    "i18next-icu": "^2.4.3",
    "idb": "^8.0.0",
    "intl-messageformat": "^11.2.8",
    "marked": "^18.0.5",
    "opusscript": "^0.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.7.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^6.0.0",
    "vitest": "^3.2.4"
  }
}
