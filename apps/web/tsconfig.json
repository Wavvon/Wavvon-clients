{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["vite/client"],
    "paths": {
      "react": ["./node_modules/@types/react/index.d.ts"],
      "react/jsx-runtime": ["./node_modules/@types/react/jsx-runtime.d.ts"],
      "react/jsx-dev-runtime": ["./node_modules/@types/react/jsx-dev-runtime.d.ts"],
      "i18next": ["./node_modules/i18next"],
      "react-i18next": ["./node_modules/react-i18next"],
      "i18next-icu": ["./node_modules/i18next-icu"],
      "@components/*": ["./src/components/*"],
      "@shared/types": ["./src/types"],
      "@shared/utils/*": ["./src/utils/*"],
      "@shared/hooks/*": ["./src/hooks/*"],
      "@shared/constants": ["./src/constants"],
      "@platform": ["./src/platform/index"],
      "@identity/*": ["./src/identity/*"],
      "@voxply/i18n": ["../i18n/index.ts"],
      "@voxply/core": ["../packages/core/src/index.ts"],
      "@voxply/ui": ["../packages/ui/src/index.ts"],
      "@voxply/ui/styles.css": ["../packages/ui/src/styles.css"]
    }
  },
  "include": ["src", "../i18n", "../packages/ui/src"],
  "exclude": ["../i18n/check-coverage.ts"]
}
